<Window x:Class="Izkalauz_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Izkalauz_WPF"
        Title="ÍzKalauz Pro - Prémium Menütervező" Height="750" Width="1050"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:CategoryToColorConverter x:Key="CatColorConv"/>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f39c12" Offset="0.0" />
            <GradientStop Color="#f1c40f" Offset="0.5" />
            <GradientStop Color="#e67e22" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#CCFFFFFF" CornerRadius="15" Margin="0,0,15,0" Padding="15">
            <StackPanel>
                <TextBlock Text="Receptek Böngészése" FontSize="26" FontWeight="Bold" Foreground="#d35400" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox" Grid.Column="0" Height="35" VerticalContentAlignment="Center" 
                             Padding="10,0" Margin="0,0,10,0" TextChanged="SearchBox_TextChanged" 
                             FontSize="14" BorderBrush="#f39c12"/>

                    <Button x:Name="BtnRandom" Grid.Column="1" Content="🎲 Mit egyek?" 
                            Click="BtnRandom_Click" Width="120" Height="35" 
                            Background="#8e44ad" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Kategória:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" Foreground="#e67e22"/>
                    <ComboBox x:Name="CategoryFilter" Width="140" SelectionChanged="CategoryFilter_SelectionChanged" Height="30">
                        <ComboBoxItem Content="Összes" IsSelected="True"/>
                        <ComboBoxItem Content="Leves"/>
                        <ComboBoxItem Content="Főétel"/>
                        <ComboBoxItem Content="Desszert"/>
                        <ComboBoxItem Content="Egytálétel"/>
                    </ComboBox>
                    <Button x:Name="BtnLoad" Content="Frissítés" Click="BtnLoad_Click" Width="100" Margin="15,0,0,0" 
                            Background="#e67e22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>

                <ListBox x:Name="RecipeList" Height="440" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Margin="0,0,5,8" Padding="10" BorderBrush="#e0e0e0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#2c3e50"/>
                                        <TextBlock Text="{Binding Category}" FontSize="13" FontWeight="ExtraBold" 
                                                   Foreground="{Binding Category, Converter={StaticResource CatColorConv}}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox Width="95" Margin="0,0,10,0" SelectedIndex="0" VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="Hétfő"/>
                                            <ComboBoxItem Content="Kedd"/>
                                            <ComboBoxItem Content="Szerda"/>
                                            <ComboBoxItem Content="Csütörtök"/>
                                            <ComboBoxItem Content="Péntek"/>
                                            <ComboBoxItem Content="Szombat"/>
                                            <ComboBoxItem Content="Vasárnap"/>
                                        </ComboBox>
                                        <Button Content="i" Click="BtnInfo_Click" Tag="{Binding}" Width="35" Height="35" Margin="0,0,5,0" Background="#3498db" Foreground="White" FontWeight="Bold"/>
                                        <Button Content="+" Click="BtnAddToMenu_Click" Tag="{Binding}" Width="35" Height="35" Background="#27ae60" Foreground="White" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#EEFFFFFF" CornerRadius="15" Padding="20">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Heti Étrendem" FontSize="22" FontWeight="Bold" Foreground="#d35400" Margin="0,0,0,20" TextAlignment="Center"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,15,0,0">
                    <Button x:Name="BtnSaveMenu" Content="MENTÉS (.txt)" Click="BtnSaveMenu_Click" Height="45" Background="#c0392b" Foreground="White" FontWeight="Bold"/>
                    <Button x:Name="BtnClearMenu" Content="Lista törlése" Click="BtnClearMenu_Click" Height="30" Background="Transparent" Foreground="#7f8c8d" BorderThickness="0" Margin="0,5,0,0"/>
                </StackPanel>
                <ListBox x:Name="WeeklyMenuList" BorderThickness="0" HorizontalContentAlignment="Stretch" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="5" Margin="0,3" Padding="10" BorderBrush="#f39c12" BorderThickness="1,0,5,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="75" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding AssignedDay}" FontWeight="Bold" Foreground="#e67e22" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                    <Button Grid.Column="2" Content="✕" Click="BtnRemoveOne_Click" Tag="{Binding}" Background="Transparent" Foreground="#c0392b" BorderThickness="0" FontWeight="Bold" Width="25"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>