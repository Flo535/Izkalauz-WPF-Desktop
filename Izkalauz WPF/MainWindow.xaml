<Window x:Class="Izkalauz_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Izkalauz_WPF"
        Title="ÍzKalauz Pro - Prémium Menütervező" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:CategoryToColorConverter x:Key="CatColorConv"/>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f39c12" Offset="0.0" />
            <GradientStop Color="#e67e22" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#DDFFFFFF" CornerRadius="15" Margin="0,0,15,0" Padding="15">
            <Grid>
                <StackPanel x:Name="RecipeListPanel">
                    <TextBlock Text="Receptek" FontSize="26" FontWeight="Bold" Foreground="#d35400" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Height="35" VerticalContentAlignment="Center" Padding="10,0" TextChanged="SearchBox_TextChanged"/>
                        <Button Grid.Column="1" Content="🎲 Random" Click="BtnRandom_Click" Width="90" Margin="10,0,0,0" Background="#8e44ad" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="CategoryFilter" Width="140" SelectionChanged="CategoryFilter_SelectionChanged" Height="30">
                            <ComboBoxItem Content="Összes" IsSelected="True"/>
                            <ComboBoxItem Content="Leves"/>
                            <ComboBoxItem Content="Főétel"/>
                            <ComboBoxItem Content="Desszert"/>
                            <ComboBoxItem Content="Egyéb"/>
                        </ComboBox>
                        <Button Content="Frissítés" Click="BtnLoad_Click" Width="100" Margin="10,0,0,0" Background="#e67e22" Foreground="White"/>
                    </StackPanel>

                    <ListBox x:Name="RecipeList" Height="500" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,5,8" Padding="10" BorderBrush="#f39c12" BorderThickness="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Category}" Foreground="{Binding Category, Converter={StaticResource CatColorConv}}" FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="ℹ" Click="BtnInfo_Click" Tag="{Binding}" Width="40" Margin="0,0,5,0" Background="#3498db" Foreground="White"/>
                                            <Button Content="+" Click="BtnAddToMenu_Click" Tag="{Binding}" Width="40" Background="#27ae60" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <Border x:Name="RecipeDetailPanel" Visibility="Collapsed" Background="White" CornerRadius="10" Padding="15">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <Button Content="← Vissza" Click="BtnCloseDetail_Click" HorizontalAlignment="Left" Foreground="#e67e22" BorderThickness="0" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Button Content="+ Hozzáadás a menühöz" Click="BtnAddFromDetail_Click" Height="35" Background="#27ae60" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                        </StackPanel>
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock x:Name="DetailName" FontSize="24" FontWeight="Bold" Foreground="#d35400" TextWrapping="Wrap"/>
                                <Separator Margin="0,10"/>
                                <TextBlock x:Name="DetailDesc" TextWrapping="Wrap" Margin="0,10"/>
                                <TextBlock Text="Elkészítés:" FontWeight="Bold"/>
                                <TextBlock x:Name="DetailHowTo" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F5FFFFFF" CornerRadius="15" Padding="15">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBlock Text="Heti Étrendem" FontSize="22" FontWeight="Bold" Foreground="#d35400" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ComboBox x:Name="TargetDaySelector" SelectedIndex="0">
                        <ComboBoxItem Content="Hétfő"/>
                        <ComboBoxItem Content="Kedd"/>
                        <ComboBoxItem Content="Szerda"/>
                        <ComboBoxItem Content="Csütörtök"/>
                        <ComboBoxItem Content="Péntek"/>
                        <ComboBoxItem Content="Szombat"/>
                        <ComboBoxItem Content="Vasárnap"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="MENTÉS (.txt)" Click="BtnSaveMenu_Click" Height="40" Background="#c0392b" Foreground="White" FontWeight="Bold"/>
                    <Button Content="Mindent töröl" Click="BtnClearMenu_Click" Background="Transparent" Foreground="Gray" BorderThickness="0"/>
                </StackPanel>

                <ListBox x:Name="WeeklyMenuList" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="5" Margin="0,2" Padding="10,5" Height="50" BorderBrush="#f39c12" BorderThickness="1,0,5,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="85"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding AssignedDay}" FontWeight="Bold" Foreground="#e67e22" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="5,0"/>
                                    <Button Grid.Column="2" Content="✕" Click="BtnRemoveOne_Click" Tag="{Binding}" Background="Transparent" Foreground="Red" BorderThickness="0" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>