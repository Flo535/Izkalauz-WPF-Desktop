<Window x:Class="Izkalauz_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Izkalauz_WPF"
        Title="ÍzKalauz Pro - Prémium Menütervező" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:CategoryToColorConverter x:Key="CatColorConv"/>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f39c12" Offset="0.0" />
            <GradientStop Color="#e67e22" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#DDFFFFFF" CornerRadius="15" Margin="0,0,15,0" Padding="15">
            <Grid>
                <StackPanel x:Name="RecipeListPanel">
                    <TextBlock Text="Receptek" FontSize="26" FontWeight="Bold" Foreground="#d35400" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Height="35" VerticalContentAlignment="Center" Padding="10,0" TextChanged="SearchBox_TextChanged"/>
                        <Button Grid.Column="1" Content="🎲 Random" Click="BtnRandom_Click" Width="90" Margin="10,0,0,0" Background="#8e44ad" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="CategoryFilter" Width="140" SelectionChanged="CategoryFilter_SelectionChanged" Height="30" SelectedIndex="0">
                            <ComboBoxItem Content="Összes"/>
                            <ComboBoxItem Content="Leves"/>
                            <ComboBoxItem Content="Főétel"/>
                            <ComboBoxItem Content="Desszert"/>
                            <ComboBoxItem Content="Egyéb"/>
                        </ComboBox>
                        <Button Content="Frissítés" Click="BtnLoad_Click" Width="100" Margin="10,0,0,0" Background="#e67e22" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>

                    <ListBox x:Name="RecipeList" Height="500" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,5,8" Padding="10" BorderBrush="#f39c12" BorderThickness="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Category}" Foreground="{Binding Category, Converter={StaticResource CatColorConv}}" FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="ℹ" Click="BtnInfo_Click" Tag="{Binding}" Width="40" Margin="0,0,5,0" Background="#3498db" Foreground="White" FontWeight="Bold"/>
                                            <Button Content="+" Click="BtnAddToMenu_Click" Tag="{Binding}" Width="40" Background="#27ae60" Foreground="White" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <Border x:Name="RecipeDetailPanel" Visibility="Collapsed" Background="White" CornerRadius="15" Padding="20">
                    <DockPanel>
                        <Button DockPanel.Dock="Top" Content="← Vissza a receptekhez" Click="BtnCloseDetail_Click" HorizontalAlignment="Left" Foreground="#e67e22" BorderThickness="0" FontWeight="Bold" Margin="0,0,0,15" Background="Transparent" Cursor="Hand"/>

                        <Button DockPanel.Dock="Bottom" Content="+ Hozzáadás a menühöz" Click="BtnAddFromDetail_Click" Height="40" Background="#27ae60" Foreground="White" FontWeight="Bold" Margin="0,10,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock x:Name="DetailName" FontSize="28" FontWeight="Bold" Foreground="#d35400" TextWrapping="Wrap"/>
                                <Border Background="#f39c12" Height="3" HorizontalAlignment="Left" Width="60" Margin="0,10,0,15"/>
                                <TextBlock x:Name="DetailDesc" TextWrapping="Wrap" Margin="0,0,0,20" FontStyle="Italic" Foreground="#7f8c8d" FontSize="14"/>

                                <TextBlock Text="🛒 Hozzávalók" FontSize="18" FontWeight="Bold" Foreground="#e67e22" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="IngredientsList" Margin="0,0,0,20">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#fdf2e9" CornerRadius="5" Margin="0,2" Padding="10,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="#34495e"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="#d35400" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding Unit}" Foreground="#7f8c8d"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="👨‍🍳 Elkészítés" FontSize="18" FontWeight="Bold" Foreground="#e67e22" Margin="0,0,0,10"/>
                                <TextBlock x:Name="DetailHowTo" TextWrapping="Wrap" FontSize="15" LineHeight="22" Foreground="#2c3e50"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F5FFFFFF" CornerRadius="15" Padding="15">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBlock Text="Heti Étrendem" FontSize="22" FontWeight="Bold" Foreground="#d35400" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ComboBox x:Name="TargetDaySelector" SelectedIndex="0" Height="30">
                        <ComboBoxItem Content="Hétfő"/>
                        <ComboBoxItem Content="Kedd"/>
                        <ComboBoxItem Content="Szerda"/>
                        <ComboBoxItem Content="Csütörtök"/>
                        <ComboBoxItem Content="Péntek"/>
                        <ComboBoxItem Content="Szombat"/>
                        <ComboBoxItem Content="Vasárnap"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="💾 MENTÉS (.txt)" Click="BtnSaveMenu_Click" Height="45" Background="#c0392b" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Button Content="🗑️ Minden törlése" Click="BtnClearMenu_Click" Background="Transparent" Foreground="#e74c3c" BorderThickness="0" FontWeight="Bold" Cursor="Hand" FontSize="12"/>
                </StackPanel>

                <ListBox x:Name="WeeklyMenuList" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,3" Background="Transparent">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                                </Border.Effect>
                                <Border Background="White" CornerRadius="5" Padding="10,8" BorderBrush="#f39c12" BorderThickness="2,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding AssignedDay}" FontWeight="Bold" Foreground="#e67e22"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="✕" Click="BtnRemoveOne_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>